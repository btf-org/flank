add_cmd() {
	# add_cmd <wd> <params>
	local wd=$1
	shift
	if [ -z "$*" ]; then
		echo 'ERROR: Must specify <scriptname> after `iflank add`'
		exit 1
	fi
	local dir_name="$*"
	if [ -d "${FLANK_ROOT}/${dir_name}" ]; then
		suffix_i=2
		while [ -d "${FLANK_ROOT}/${dir_name}_${suffix_i}" ]; do
			suffix_i=$((suffix_i + 1))
		done
		dir_name="${dir_name}_${suffix_i}"
		echo 'WARNING: '"$FLANK_ROOT/$*"' already exists. Creating '"$dir_name"
	fi
	mkdir "${FLANK_ROOT}/${dir_name}"
	cat >"${FLANK_ROOT}/${dir_name}/template.sh" <<EOF
