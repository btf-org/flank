url_encode() {
    local string="$1"
    local encoded=""
    local i c

    for (( i=0; i<${#string}; i++ )); do
        c="${string:$i:1}"
        case "$c" in
            [a-zA-Z0-9.~_-]) encoded+="$c" ;;
            *) encoded+=$(printf '%%%02X' "'$c") ;;
        esac
    done

    printf '%s' "$encoded"
}
awk_sub_default='
BEGIN {
  target = "@default ${" key "}"
  prefix = "@default "
  len = length(target)
}
{
  out = ""
  start = $0

  while ((i = index(start, target)) > 0) {
    out = out substr(start, 1, i-1) prefix val
    start = substr(start, i + len)
  }

  out = out start
  print out
}'
eval_multistep_form() {
