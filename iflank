#!/usr/bin/env bash

if [ -d /var/lib/flank ]; then
	FLANK_ROOT=/var/lib/flank
elif [ -d /opt/homebrew/var/flank ]; then
	FLANK_ROOT=/opt/homebrew/var/flank
elif [ -d /usr/local/var/flank ]; then
	FLANK_ROOT=/usr/local/var/flank
elif [ -n $(which brew) && $(brew --prefix) >0 ]; then
	FLANK_ROOT=$(brew --prefix)/var
else
	echo "Cannot find flank root!"
	exit
fi

get_value() {
	input="$1"
	target_key="$2"

	old_ifs="$IFS"
	IFS=$(printf '\037')
	for pair in $input; do
		key="${pair%%=*}"
		value="${pair#*=}"
		if [ "$key" = "$target_key" ]; then
			IFS="$old_ifs"
			printf '%s\n' "$value"
			return 0
		fi
	done

	IFS="$old_ifs"
	return 1
}
get_value_url() {
	# get_value_url <kvs> <keyname>
	local _kvs="$1"
	local _keyname="$2"
	# isolate matching key
	_value=$(printf '%s' "$_kvs" \
		| tr '&' '\n' \
		| awk -F= -v key="$_keyname" '$1 == key {print $2; exit}')

	# URL decode (minimal, POSIX-compatible)
	printf '%s\n' "$_value" \
	| sed -e 's/+/ /g' \
	      -e 's/%20/ /g' \
	      -e 's/%21/!/g' \
	      -e 's/%22/"/g' \
	      -e 's/%23/#/g' \
	      -e 's/%24/$/g' \
	      -e 's/%25/%/g' \
	      -e 's/%26/\&/g' \
	      -e 's/%27/'"'"'/g' \
	      -e 's/%28/(/g' \
	      -e 's/%29/)/g'
}
url_2_awk() {
	# url_2_awk <url_args>
	# url encoding to Flank awk encoding
	local _args="$1"
	local _arglist=''
	local _prev_key=''

	for kv in $(echo "$_args" | tr '&' '\n' | sort); do
		local _decoded_kv=$(printf '%b' "$(sed 's/+/ /g; s/%/\\x/g' <<<${kv})")

		local _key="${_decoded_kv%%=*}"
		local _val="${_decoded_kv#*=}"

		if [ "${_key%\[\]}" != "$_key" ]; then
			# Array key - strip [] and append with newline if same key
			local _base_key="${_key%\[\]}"
			if [ "$_arglist" = '' ]; then
				_arglist="${_base_key}=${_val}"
			elif [ "$_base_key" = "$_prev_key" ]; then
				_arglist="${_arglist}"$'\n'"${_val}"
			else
				_arglist="${_arglist}"$'\x1F'"${_base_key}=${_val}"
			fi
			_prev_key="$_base_key"
		else
			# Normal key
			if [ "$_arglist" = '' ]; then
				_arglist="${_key}=${_val}"
			else
				_arglist="${_arglist}"$'\x1F'"${_key}=${_val}"
			fi
			_prev_key="$_key"
		fi
	done
	printf '%s' "$_arglist"
}
