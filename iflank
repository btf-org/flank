awk_parse_vars='
# match annotation lines
/^# *\$\{[A-Za-z_][A-Za-z0-9_]*(:[+-][^}]*)?\} / {
	line = $0
	match(line, /\$\{[A-Za-z_][A-Za-z0-9_]*(:[+-][^}]*)?\}/)
    var = substr(line, RSTART, RLENGTH)

    # strip "# ${var} "
    sub(/^# *\$\{[A-Za-z_][A-Za-z0-9_]*\} */, "", line)

	if (var_concat[var] == "") {
		var_concat[var] = line
	} else {
		var_concat[var] = var_concat[var] " " line
	}
}

END {
	kv_string=""
    for (v in var_concat) {
		n = split(var_concat[v], values, /(^|[[:space:]][[:space:]]*)@[a-z][a-z]*/)
		for(j in values){
			sub(/^[[:space:]]*/, "", values[j])
			sub(/[[:space:]]*$/, "", values[j])
		}
		s = var_concat[v]
		i = 1
		while (match(s, /(^|[[:space:]][[:space:]]*)@[a-z][a-z]*/)) {
			key = substr(s, RSTART, RLENGTH)
			# strip leading spaces
			sub(/^ */, "", key)
			s = substr(s, RSTART + RLENGTH)
			ann[key] = values[i+1]
			i++
		}

		ctrl["@description"] = ""
		ctrl["@type"] = "text"
		ctrl["@colspan"] = 2
		ctrl["@capturetab"] = 0
		ctrl["@values"] = ""
		ctrl["@default"] = ""
		ctrl["@input"] = 1
		ctrl["@textarea"] = 0
		ctrl["@select"] = 0
		for (key in ann){
			if (key == "@description") {
				ctrl["@description"] = ann[key]
			} else if (key == "@type") {
				ctrl["@type"] = ann[key]
			} else if (key == "@colspan") {
				ctrl["@colspan"] = ann[key]
			} else if (key == "@capturetab") {
				ctrl["@capturetab"] = 1
			} else if (key == "@values") {
				ctrl["@values"] = ann[key]
			} else if (key == "@default") {
				ctrl["@default"] = ann[key]
				if (ctrl["@default"] ~ /^`.*`$/) {
					cmd = substr(ctrl["@default"], 2, length(ctrl["@default"]) - 2)
					output=""
					while ((cmd | getline line) > 0) {
						output = (output == "") ? line : output "\n" line
					}
					close(cmd)
					ctrl["@default"]=output
				} else {
					gsub(/\\n/, "\n", ctrl["@default"])
				}
			} else if (key == "@input"){
				ctrl["@input"] = 1
			} else if (key == "@select"){
				ctrl["@select"] = 1
			} else if (key == "@textarea"){
				ctrl["@textarea"] = 1
				if (!("@colspan" in ann)) {
					ctrl["@colspan"] = 6
				}
			}
		}	

		varname_stripped=v
		sub(/^ *\$\{/, "", varname_stripped)
		sub(/\} *$/, "", varname_stripped)

		if(RETURN_KV){
			if(kv_string == ""){
				kv_string=varname_stripped"='\''<value>'\''"
			} else {
				kv_string=kv_string" "varname_stripped"='\''<value>'\''"
			}
			delete ann
			continue
		}

		html = "<div class=\"col-start-1 col-span-"ctrl["@colspan"]"\"><div>"varname_stripped"</div>"
		if(ctrl["@description"] != ""){
			html=html"<div class=\"font-size-0_8\">"ctrl["@description"]"</div>"
		}
		if(ctrl["@input"] == 1 && (ctrl["@type"] == "checkbox" || ctrl["@type"] == "radio")){
			if (ctrl["@values"] ~ /^`.*`$/) {
				cmd = substr(ctrl["@values"], 2, length(ctrl["@values"]) - 2)
				while ((cmd | getline line) > 0) {
					required_flag=""
					if(ctrl["@type"] == "radio"){
						required_flag="required "
					}
					brackets=""
					if(ctrl["@type"] == "checkbox"){
						brackets="[]"
					}
					html=html"<label class=\"block\"><input "required_flag"type=\""ctrl["@type"]"\" name=\""varname_stripped brackets"\" value=\""line"\"> "line"</label>"
				}
				close(cmd)
			}
		} else if(ctrl["@select"] == 1) {
			html=html"<select required name=\""varname_stripped"\">"
			if (ctrl["@values"] ~ /^`.*`$/) {
				cmd = substr(ctrl["@values"], 2, length(ctrl["@values"]) - 2)
				while ((cmd | getline line) > 0) {
					selected=""
					if(line == ctrl["@default"]){
						selected=" selected"
					}
					html=html"<option value=\""line"\""selected">"line"</option>"
				}
				close(cmd)
			}
			html=html"</select>"
		} else {
			if(ctrl["@textarea"] == 1){
				html=html"<textarea required class=\"w-100p\" "
			} else {
				html=html"<input required class=\"w-100p\" type=\""ctrl["@type"]"\" "
			}
			if(ctrl["@capturetab"]){
				html=html"onkeydown=\"tab(event, this)\" "
			}
			html=html"name=\""varname_stripped"\""
			if(ctrl["@textarea"] == 1){
				html=html">"
				if(ctrl["@default"]){
					html=html""ctrl["@default"]
				}
				html=html"</textarea>"
			} else {
				if(ctrl["@default"]){
					html=html" value=\""ctrl["@default"]"\""
				}
				html=html"/>"
			}
		}
		html = html"</div>"
		print html
		delete ann
    }
	if(RETURN_KV){
		print kv_string
	}
}'
