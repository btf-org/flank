help_msg() {
	printf 'Usage: iflank [run <path>] [add <scriptname>] [--http-mode | -h]\n'
}

# This traps SIGPIPE, which would get sent if this program tried to write to a broken pipe
trap "echo 'server disconnected (write pipe)'; exit 1" PIPE

while [ "$1" != "" ]; do
	case $1 in
	run)
		# iflank  run   <cmd dir> [--output_key <key>] k1=v1 k2=v2
		# run_cmd fg|bg <cmd dir> [--output_key <key>] [--arglist k1=v1FLNKDLMk2=v2] k1=v1 k2=v2
		set -e
		shift
		# if your params are "a", "b merry" and "c"
		# "$@" expands to "a" "b merry" "c"
		# $@ expands to a b merry c
		# "$*" expands to "a b merry c"
		p_cmd_dir="$1"
		shift
		arglist=''
		ok_flag=''
		ok_value=''
		while [ "$1" != "" ]; do
			case $1 in
			--output_key)
				ok_flag='--output_key'
				shift
				ok_value="$1"
				;;
			*)
				if [ -z "$arglist" ]; then
					arglist="$1"
				else
					arglist="${arglist}"$'\x1F'"$1"
				fi
				;;
			esac
			shift
		done
		run_cmd "fg" "$p_cmd_dir" ${ok_flag:+"$ok_flag" "$ok_value"} --arglist "$arglist"
		exit_code=$?
		exit $exit_code
		;;
	add)
		shift
		add_cmd "$PWD" "$@"
		exit
		;;
	-h | --help)
		help_msg
		exit
		;;
	*)
		help_msg
		exit 1
		;;
	esac
	shift
done

